classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +all_tasks() list
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task) None
        +incomplete_tasks() list
    }

    class Task {
        +str title
        +str time
        +int duration_minutes
        +str priority
        +str frequency
        +date due_date
        +bool completed
        +mark_complete() None
    }

    class Scheduler {
        +Owner owner
        +sort_by_time(tasks) list
        +filter_tasks(pet_name, completed) list
        +detect_conflicts(tasks) list
        +mark_task_complete(pet_name, task_title) Task
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : organizes tasks for
